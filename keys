CREATE TABLE õpilane_kursus (
    õpilane_id INT,
    kursus_id INT,
    liitumise_kuupäev DATE,
    PRIMARY KEY (õpilane_id, kursus_id),-- Compound Key
    FOREIGN KEY (õpilane_id) REFERENCES õpilased(õpilane_id),
    FOREIGN KEY (kursus_id) REFERENCES kursused(kursus_id)
);

