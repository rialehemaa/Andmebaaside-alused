CREATE TABLE sõidukid (
    sõiduk_id INT PRIMARY KEY,        -- valitud Candidate Key → Primary Key
    registreerimisnumber CHAR(6) UNIQUE,  -- Candidate Key → saab Alternate Key-ks
    vin_kood CHAR(17) UNIQUE,             -- Candidate Key → saab Alternate Key-ks
    mark VARCHAR(50),
    mudel VARCHAR(50)
);

