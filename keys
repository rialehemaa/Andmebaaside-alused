CREATE TABLE raamatud (
    raamat_id INT PRIMARY KEY, -- Primary Key (valitud Candidate Key)
    isbn CHAR(13) UNIQUE, -- Alternate Key (Candidate Key, mis ei valitud PK-ks)
    pealkiri VARCHAR(200),
    autor VARCHAR(100),
    aasta INT
);

