SELECT * FROM auto;

--andmete sorteerimine
--kasvavas järjekorras ASC
SELECT * FROM auto
ORDER BY v_aasta;

--kahanevas järjekorras
SELECT * FROM auto
ORDER BY v_aasta DESC;

--kuvab ainult kaks veergu
SELECT mark, model FROM auto;

--kordavate väärtuste välistamine DISTINCT
SELECT DISTINCT mark FROM auto;

--võrdlemine
--1. suurem kui >, väiksem kui <, võrdub =
--leia kõik autod, kus on v_aasta 2000 peale
SELECT mark, model, v_aasta
FROM auto
WHERE v_aasta >= 2000;

--leia kõik autod mis on v_aasta vahemikus 2000-2005
SELECT mark, model, v_aasta
FROM auto
WHERE v_aasta BETWEEN 2000 AND 2005;

SELECT mark, model, v_aasta
FROM auto
WHERE v_aasta >= 2000 AND v_aasta <= 2005;

--2. võrdlemine tekst või sümbooliga
--kuvab kõik ford'i autod
SELECT mark, model, v_aasta
FROM auto
WHERE mark LIKE 'Ford';

--IN lause kuvab vastavus loetelus -соответствие перечислению
SELECT mark, model, v_aasta
FROM auto
WHERE mark IN ('Ford', 'Nissan', 'Jeep');

--ilma IN
SELECT mark, model, v_aasta
FROM auto
WHERE mark LIKE 'Ford' OR mark LIKE 'Nissan' OR mark LIKE 'Jeep';

--vastavus mustrile - шаблон
--algab F tähega
SELECT mark, model, v_aasta
FROM auto
WHERE mark LIKE 'F%';
--lõpeb p -tähega
SELECT mark, model, v_aasta
FROM auto
WHERE mark LIKE '%p';

--sisaldab a-täht
SELECT mark, model, v_aasta
FROM auto
WHERE mark LIKE '%a%';

--kuvada esimest 5 mudeli
select * from auto;
SELECT TOP 5 model, varv
FROM auto
WHERE varv like 'red'
Order by varv;

--agregaat funktsioonid: SUM, MIN, MAX, AVG, COUNT
--SELECT COUNT(*) FROM auto;
SELECT COUNT(*) AS autodeArv FROM auto;
SELECT MAX(v_aasta) AS suuremAasta FROM auto;
--keerulisem variant
SELECT mark, AVG(v_aasta)
FROM auto
GROUP BY mark;
